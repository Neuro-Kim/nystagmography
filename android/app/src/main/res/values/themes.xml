<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Nystagmography" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="colorPrimary">#007AFF</item>
        <item name="colorPrimaryVariant">#0056B3</item>
    </style>

    <style name="Theme.Nystagmography.Result" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="android:statusBarColor">#F2F2F7</item>
        <item name="android:navigationBarColor">#F2F2F7</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowBackground">#F2F2F7</item>
        <item name="materialButtonStyle">@style/Widget.App.Button.Plain</item>
    </style>

    <style name="Widget.App.Button.Plain" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@null</item>
    </style>
</resources>
