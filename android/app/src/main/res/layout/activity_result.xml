<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F2F7"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="24dp"
        android:paddingBottom="32dp">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Results"
            android:textSize="34sp"
            android:textColor="#000000"
            android:textStyle="bold"
            android:layout_marginBottom="20dp" />

        <!-- Horizontal graph card -->
        <com.nystagmography.GraphView
            android:id="@+id/graphHorizontal"
            android:layout_width="match_parent"
            android:layout_height="280dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_card"
            android:elevation="0dp"
            android:padding="4dp" />

        <!-- Vertical graph card -->
        <com.nystagmography.GraphView
            android:id="@+id/graphVertical"
            android:layout_width="match_parent"
            android:layout_height="280dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_card"
            android:elevation="0dp"
            android:padding="4dp" />

        <!-- SPV graph card -->
        <com.nystagmography.GraphView
            android:id="@+id/graphSPV"
            android:layout_width="match_parent"
            android:layout_height="280dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_card"
            android:elevation="0dp"
            android:padding="4dp" />

        <!-- Analysis card -->
        <TextView
            android:id="@+id/tvAnalysis"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#3C3C43"
            android:lineSpacingExtra="4dp"
            android:fontFamily="monospace"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_card" />

        <!-- Buttons -->
        <Button
            android:id="@+id/btnBack"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_pill_button"
            android:text="Back to Camera"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textAllCaps="false"
            android:stateListAnimator="@null" />

        <Button
            android:id="@+id/btnSavePng"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_pill_button_secondary"
            android:text="Save as PNG"
            android:textColor="#007AFF"
            android:textSize="17sp"
            android:textAllCaps="false"
            android:stateListAnimator="@null" />
    </LinearLayout>
</ScrollView>
